{
  "name": "blog",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:worker\" \"npm:dev:frontend\"",
    "dev:frontend": "vite -c vite.start.config.ts",
    "dev:worker": "npm run build && wrangler dev --config wrangler.dev.toml --port 8788 --persist-to .wrangler/state",
    "build": "vite build -c vite.start.config.ts",
    "deploy": "npm run build && wrangler deploy",
    "deploy:production": "npm run build && wrangler deploy --env production",
    "deploy:stage": "npm run build && wrangler deploy",
    "test": "node --import @swc-node/register/esm-register --test",
    "test:ui:local": "npx playwright test --config playwright.local.config.ts",
    "test:ui:serve": "npm run build && wrangler dev --config wrangler.dev.toml --port 8788 --persist-to .wrangler/state-playwright",
    "lint": "oxlint -c oxlintrc.json && eslint \"{src,tests}/**/*.{ts,tsx}\"",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.168.7",
    "@tanstack/react-start": "^1.167.12",
    "hono": "^4.12.9",
    "mermaid": "^11.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@playwright/test": "^1.58.2",
    "@swc-node/register": "^1.11.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "oxlint": "^1.56.0",
    "postcss": "^8.5.8",
    "postcss-preset-env": "^11.2.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "wrangler": "^4.78.0"
  }
}
